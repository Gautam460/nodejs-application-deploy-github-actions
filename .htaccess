<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType application/json .json
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Proxy /api and /uploads requests to the Node.js backend running on PM2 (Port 4000)
  RewriteRule ^api/(.*)$ http://127.0.0.1:4000/api/$1 [P,L]
  RewriteRule ^uploads/(.*)$ http://127.0.0.1:4000/uploads/$1 [P,L]

  # React Router fallback: if the file or directory doesn't exist, serve index.html
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
